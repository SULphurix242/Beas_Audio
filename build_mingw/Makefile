third_party/pffft/pffft/pffft.s: third_party/pffft/pffft/pffft.c.s
.PHONY : third_party/pffft/pffft/pffft.s

# target to generate assembly for a file
third_party/pffft/pffft/pffft.c.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles\pffft.dir\build.make CMakeFiles/pffft.dir/third_party/pffft/pffft/pffft.c.s
.PHONY : third_party/pffft/pffft/pffft.c.s

